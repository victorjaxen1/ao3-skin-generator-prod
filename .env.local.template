# Copy this file and rename to .env.local
# Then fill in your actual Cloudinary credentials

# Cloudinary Configuration
# Get your cloud name from: https://cloudinary.com/console
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=

# Create an unsigned upload preset in Cloudinary Settings > Upload > Upload presets
NEXT_PUBLIC_CLOUDINARY_UPLOAD_PRESET=

# Example values (replace with your actual values):
# NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=demo-cloud-123
# NEXT_PUBLIC_CLOUDINARY_UPLOAD_PRESET=ao3_social_messages
